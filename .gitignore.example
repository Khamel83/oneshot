# .gitignore - Git ignore patterns for ONE_SHOT projects
#
# Copy relevant sections to your project's .gitignore

# ============================================================================
# Secrets (NEVER commit plaintext)
# All secrets come from central repo, nothing stored in project
# ============================================================================
.env

# ============================================================================
# Python
# ============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
ENV/
*.egg-info/
dist/
build/
.pytest_cache/

# ============================================================================
# Node.js
# ============================================================================
node_modules/
npm-debug.log
yarn-error.log
.npm

# ============================================================================
# IDEs
# ============================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# ============================================================================
# Databases
# ============================================================================
*.db
*.sqlite
*.sqlite3

# But allow example/test databases
!example.db
!test.db

# ============================================================================
# Logs
# ============================================================================
*.log
logs/
*.pid

# ============================================================================
# Temporary files
# ============================================================================
tmp/
temp/
*.tmp
*.cache

# ============================================================================
# OS
# ============================================================================
.DS_Store
Thumbs.db
