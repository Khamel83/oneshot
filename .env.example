# .env.example - Reference only (not used in ONE_SHOT projects)
#
# ONE_SHOT uses CENTRAL SECRETS pattern:
# - All secrets stored in central GitHub repo (github.com/you/secrets-vault)
# - Run ./scripts/setup_secrets.sh to pull secrets from central repo
# - This creates .env automatically with ALL your secrets
#
# To add new secrets:
# 1. ./scripts/update_secrets.sh
# 2. Add your secret
# 3. Save and commit
# 4. All projects get the update
#
# See CENTRAL_SECRETS.md for details

# ============================================================================
# Common secrets you might have in central repo:
# ============================================================================

# OPENROUTER_API_KEY=sk-or-v1-...
# GITHUB_TOKEN=ghp_...
# FIRECRAWL_API_KEY=fc-...
# DATABASE_URL=postgresql://...
# STRIPE_SECRET_KEY=sk_test_...

# All of these come from central repo, not this file
